---
import { type Locale } from "../i18n/config";
import { getMessages } from "../i18n";
import { getTagUrl, tagToSlug } from "../utils/content";

type Props = {
  tags: string[];
  locale: Locale;
  activeTagSlug?: string;
};

const { tags, locale, activeTagSlug = "all" } = Astro.props;
const messages = getMessages(locale);
---

<div class="tag-filter-scroll">
  <nav class="tag-filter" aria-label="Filter by tag">
    <button
      type="button"
      class:list={["tag-tab", { active: activeTagSlug === "all" }]}
      data-tag="all"
    >
      {messages.filter.all}
    </button>
    {tags.map((tag) => {
      const slug = tagToSlug(tag);
      return (
        <a
          class:list={["tag-tab", { active: activeTagSlug === slug }]}
          data-tag={slug}
          href={getTagUrl(tag, locale)}
        >
          {tag}
        </a>
      );
    })}
  </nav>
</div>

<style>
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .tag-tab {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    border-radius: var(--radius-card);
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-text-default);
    background: transparent;
    border: none;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease,
      border-color 0.15s ease;
  }

  .tag-tab:hover {
    background: var(--color-accent-subtle);
    color: var(--color-accent-fg);
  }

  .tag-tab:focus-visible {
    outline: 2px solid var(--color-aquarius-600);
    outline-offset: 2px;
  }

  .tag-tab.active {
    background: var(--color-text-strong);
    color: var(--color-white);
  }

  :global([data-theme="dark"]) .tag-tab.active {
    color: var(--color-bg-default);
  }

  @media (max-width: 640px) {
    .tag-filter-scroll {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin: 0 -15px;
      padding: 4px 15px;
      scrollbar-width: none;
      min-width: 0;
      max-width: 100vw;
    }

    .tag-filter-scroll::-webkit-scrollbar {
      display: none;
    }

    .tag-filter {
      flex-wrap: nowrap;
      width: max-content;
    }

    .tag-tab {
      flex: 0 0 auto;
      border-radius: var(--radius-chip);
      border: 1px solid var(--color-border-default);
    }

    .tag-tab.active {
      border-color: transparent;
    }
  }
</style>
