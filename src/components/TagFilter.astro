---
import { type Locale } from "../i18n/config";
import { getMessages } from "../i18n";
import { getTagUrl, tagToSlug } from "../utils/content";

type Props = {
  tags: string[];
  locale: Locale;
  activeTagSlug?: string;
};

const { tags, locale, activeTagSlug = "all" } = Astro.props;
const messages = getMessages(locale);
---

<div class="tag-carousel" data-tag-carousel>
  <button
    type="button"
    class="carousel-arrow prev"
    data-carousel-prev
    hidden
    aria-label={messages.filter.scrollPrev}
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <div class="tag-filter-scroll" data-tag-scroll>
    <nav class="tag-filter" aria-label="Filter by tag">
      <button
        type="button"
        class:list={["tag-tab", { active: activeTagSlug === "all" }]}
        data-tag="all"
      >
        {messages.filter.all}
      </button>
      {tags.map((tag) => {
        const slug = tagToSlug(tag);
        return (
          <a
            class:list={["tag-tab", { active: activeTagSlug === slug }]}
            data-tag={slug}
            href={getTagUrl(tag, locale)}
          >
            {tag}
          </a>
        );
      })}
    </nav>
  </div>
  <button
    type="button"
    class="carousel-arrow next"
    data-carousel-next
    hidden
    aria-label={messages.filter.scrollNext}
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>
</div>

<style>
  .tag-carousel {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1 1 auto;
    min-width: 0;
  }

  .tag-filter-scroll {
    min-width: 0;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }

  .tag-filter-scroll::-webkit-scrollbar {
    display: none;
  }

  .tag-filter {
    display: flex;
    flex-wrap: nowrap;
    gap: 8px;
    align-items: center;
    width: max-content;
  }

  .tag-tab {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    padding: 8px 14px;
    border-radius: var(--radius-card);
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-text-default);
    background: transparent;
    border: none;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease,
      border-color 0.15s ease;
  }

  .tag-tab:hover {
    background: var(--color-accent-subtle);
    color: var(--color-accent-fg);
  }

  .tag-tab:focus-visible {
    outline: 2px solid var(--color-aquarius-600);
    outline-offset: 2px;
  }

  .tag-tab.active {
    background: var(--color-text-strong);
    color: var(--color-white);
  }

  :global([data-theme="dark"]) .tag-tab.active {
    color: var(--color-bg-default);
  }

  .carousel-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 32px;
    height: 32px;
    padding: 0;
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-chip);
    background: var(--color-bg-surface);
    color: var(--color-text-default);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .carousel-arrow:hover {
    background: var(--color-accent-subtle);
    color: var(--color-accent-fg);
  }

  .carousel-arrow:focus-visible {
    outline: 2px solid var(--color-aquarius-600);
    outline-offset: 2px;
  }

  .carousel-arrow[hidden] {
    display: none;
  }

  @media (max-width: 640px) {
    .tag-carousel {
      margin: 0 -15px;
      padding: 4px 15px;
      max-width: 100vw;
    }

    .carousel-arrow {
      display: none;
    }

    .tag-tab {
      flex: 0 0 auto;
      border-radius: var(--radius-chip);
      border: 1px solid var(--color-border-default);
    }

    .tag-tab.active {
      border-color: transparent;
    }
  }
</style>

<script>
  const desktop = window.matchMedia("(min-width: 641px)");

  document.querySelectorAll<HTMLElement>("[data-tag-carousel]").forEach((carousel) => {
    const scroll = carousel.querySelector<HTMLElement>("[data-tag-scroll]");
    const prev = carousel.querySelector<HTMLButtonElement>("[data-carousel-prev]");
    const next = carousel.querySelector<HTMLButtonElement>("[data-carousel-next]");
    if (!scroll || !prev || !next) return;

    const updateArrows = () => {
      if (!desktop.matches) {
        prev.hidden = true;
        next.hidden = true;
        return;
      }
      const maxScroll = scroll.scrollWidth - scroll.clientWidth;
      prev.hidden = scroll.scrollLeft <= 1;
      next.hidden = scroll.scrollLeft >= maxScroll - 1;
    };

    const scrollByStep = (direction: 1 | -1) => {
      scroll.scrollBy({
        left: direction * scroll.clientWidth * 0.8,
        behavior: "smooth",
      });
    };

    prev.addEventListener("click", () => scrollByStep(-1));
    next.addEventListener("click", () => scrollByStep(1));
    scroll.addEventListener("scroll", updateArrows, { passive: true });

    if ("ResizeObserver" in window) {
      new ResizeObserver(updateArrows).observe(scroll);
    }
    desktop.addEventListener("change", updateArrows);

    updateArrows();
  });
</script>
