---
import { type Locale, getLocaleFromAstro } from "../i18n/config";
import { getMessages } from "../i18n";

type Props = {
  locale?: Locale;
};

const locale = getLocaleFromAstro(Astro);
const messages = getMessages(locale);
---

<label class="search-bar">
  <span class="sr-only">{messages.filter.searchPlaceholder}</span>
  <svg
    class="icon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="7"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
  </svg>
  <input
    type="search"
    name="search"
    data-search-input
    data-search-in-placeholder={messages.filter.searchInPlaceholder}
    placeholder={messages.filter.searchPlaceholder}
    autocomplete="off"
  />
</label>

<style>
  .search-bar {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-card);
    color: var(--color-text-muted);
    flex: 0 0 240px;
    min-width: 240px;
    transition: flex-grow 0.2s ease, flex-basis 0.2s ease;
  }

  .search-bar:focus-within {
    border-color: var(--color-aquarius-600);
    color: var(--color-aquarius-700);
  }

  .search-bar input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 16px;
    font-family: inherit;
    color: var(--color-text-strong);
    min-width: 0;
    padding: 4px 0;
  }

  .search-bar input::placeholder {
    color: var(--color-text-muted);
  }

  .icon {
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .search-bar {
      display: flex;
      flex: 0 0 auto;
      width: 100%;
      min-width: 0;
    }
  }
</style>
