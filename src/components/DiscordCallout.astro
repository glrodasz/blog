---
import Container from "./Container.astro";
import { type Locale, getLocaleFromAstro } from "../i18n/config";
import { getMessages } from "../i18n";

type Props = {
  locale?: Locale;
};

const locale = getLocaleFromAstro(Astro);
const messages = getMessages(locale);
---

<section class="discord-callout">
  <Container>
    <div class="inner">
      <div class="text">
        <h2 class="title">{messages.discord.title}</h2>
        <p class="subtitle">{messages.discord.subtitle}</p>
      </div>
      <a
        href="https://undf.sh/discord"
        class="cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          fill="currentColor"
          viewBox="0 0 16 16"
          aria-hidden="true"
        >
          <path
            d="M13.545 2.907a13.2 13.2 0 0 0-3.257-1.011.05.05 0 0 0-.052.025c-.141.25-.297.577-.406.833a12.2 12.2 0 0 0-3.658 0 8 8 0 0 0-.412-.833.05.05 0 0 0-.052-.025c-1.125.194-2.22.534-3.257 1.011a.04.04 0 0 0-.021.018C.356 6.024-.213 9.047.066 12.032q.003.022.021.037a13.3 13.3 0 0 0 3.995 2.02.05.05 0 0 0 .056-.019q.463-.63.818-1.329a.05.05 0 0 0-.01-.059l-.018-.011a9 9 0 0 1-1.248-.595.05.05 0 0 1-.02-.066l.015-.019q.127-.095.248-.195a.05.05 0 0 1 .051-.007c2.619 1.196 5.454 1.196 8.041 0a.05.05 0 0 1 .053.007q.121.1.248.195a.05.05 0 0 1-.004.085 8 8 0 0 1-1.249.594.05.05 0 0 0-.03.03.05.05 0 0 0 .003.041c.24.465.515.909.817 1.329a.05.05 0 0 0 .056.019 13.2 13.2 0 0 0 4.001-2.02.05.05 0 0 0 .021-.037c.334-3.451-.559-6.449-2.366-9.106a.03.03 0 0 0-.02-.019m-8.198 7.307c-.789 0-1.438-.724-1.438-1.612s.637-1.613 1.438-1.613c.807 0 1.45.73 1.438 1.613 0 .888-.637 1.612-1.438 1.612m5.316 0c-.788 0-1.438-.724-1.438-1.612s.637-1.613 1.438-1.613c.807 0 1.451.73 1.438 1.613 0 .888-.631 1.612-1.438 1.612"
          ></path>
        </svg>
        <span>{messages.discord.cta}</span>
      </a>
    </div>
  </Container>
</section>

<style>
  .discord-callout {
    padding: 2em 0;
  }

  .inner {
    background: var(--color-aquarius-900);
    color: var(--color-white);
    border-radius: var(--radius-card);
    padding: 1.75em 2em;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5em;
  }

  .title {
    margin: 0 0 4px;
    color: var(--color-white);
    font-size: 1.4em;
    line-height: 1.2;
  }

  .subtitle {
    margin: 0;
    color: var(--color-text-on-inverse-muted);
    font-size: 0.9em;
    line-height: 1.4;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--color-aquarius-600);
    color: var(--color-white);
    font-weight: 700;
    padding: 14px 22px;
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: background 0.15s ease;
    flex-shrink: 0;
  }

  .cta:hover {
    background: var(--color-aquarius-700);
  }

  .cta:focus-visible {
    outline: 2px solid var(--color-white);
    outline-offset: 2px;
    box-shadow: 0 0 0 4px var(--color-aquarius-700);
  }

  @media (max-width: 768px) {
    .inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.25em 1.25em;
    }
  }
</style>
