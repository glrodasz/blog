---
import Container from "./Container.astro";
import SubscribeForm from "./SubscribeForm.astro";
import FollowButtons from "./FollowButtons.astro";
import LanguageSelector from "./LanguageSelector.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { type Locale, getLocaleFromAstro } from "../i18n/config";
import { getMessages } from "../i18n";

type Props = {
  locale?: Locale;
};

const locale = getLocaleFromAstro(Astro);
const messages = getMessages(locale);
const currentPath = Astro.url.pathname;
const today = new Date();
---

<footer id="subscribe">
  <div class="subscribe-band">
    <Container>
      <div class="subscribe-inner">
        <div class="subscribe-text">
          <h2 class="subscribe-title">{messages.subscribe.title}</h2>
          <SubscribeForm locale={locale} />
        </div>
        <FollowButtons locale={locale} />
      </div>
    </Container>
  </div>
  <div class="copy-band">
    <Container>
      <div class="copy-inner">
        <span class="copy copy-full">
          {messages.site.title} {messages.footer.creditBy} <a href="https://guillermorodas.com" target="_blank" rel="noopener noreferrer">{messages.author.name}</a> &nbsp;&copy;&nbsp; {today.getFullYear()}
        </span>
        <span class="copy copy-short">
          {messages.site.title} &nbsp;&copy;&nbsp; {today.getFullYear()}
        </span>
        <div class="footer-utilities">
          <LanguageSelector currentLocale={locale} currentPath={currentPath} />
          <ThemeToggle />
        </div>
      </div>
    </Container>
  </div>
</footer>

<style>
  footer {
    background: var(--color-bg-inverse);
    color: var(--color-text-on-inverse);
    border-top: 1px solid var(--color-border-default);
    margin-top: 0;
  }

  .subscribe-band {
    padding: 2.5em 0;
    background: var(--color-bg-inverse-raised);
  }

  .subscribe-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2em;
    flex-wrap: wrap;
  }

  .subscribe-text {
    display: flex;
    flex-direction: column;
    gap: 1em;
    flex: 1;
    min-width: 280px;
  }

  .subscribe-title {
    margin: 0;
    color: var(--color-aquarius-600);
    font-size: 1.4em;
    line-height: 1.2;
  }

  .copy-band {
    padding: 1em 0;
  }

  .copy-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1em;
  }

  .copy {
    color: var(--color-text-on-inverse-muted);
    font-size: 0.75em;
  }

  .copy-short {
    display: none;
  }

  .copy a {
    color: var(--color-text-on-inverse-muted);
    text-decoration: underline;
  }

  .copy a:hover {
    color: var(--color-text-on-inverse);
  }

  .footer-utilities {
    display: flex;
    align-items: center;
    gap: 0.25em;
    flex-shrink: 0;
    font-size: 0.75em;
  }

  .footer-utilities :global(.language-toggle),
  .footer-utilities :global(.theme-toggle) {
    color: var(--color-text-on-inverse-muted);
  }

  .footer-utilities :global(.language-label),
  .footer-utilities :global(.theme-label) {
    font-size: inherit;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .footer-utilities :global(.language-toggle:hover),
  .footer-utilities :global(.theme-toggle:hover) {
    background-color: rgba(255, 255, 255, 8%);
    color: var(--color-text-on-inverse);
  }

  .footer-utilities :global(.language-toggle:focus-visible),
  .footer-utilities :global(.theme-toggle:focus-visible) {
    outline-color: var(--color-text-on-inverse);
  }

  @media (max-width: 640px) {
    .subscribe-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .copy-full {
      display: none;
    }

    .copy-short {
      display: inline;
    }

    .copy-inner {
      flex-direction: row;
      align-items: center;
      gap: 0.5em;
    }
  }
</style>
