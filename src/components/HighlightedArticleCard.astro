---
import TagChip from "./TagChip.astro";
import FormattedDate from "./FormattedDate.astro";
import {
  type Post,
  getPostUrl,
  calculateReadingTime,
  getPostTags,
  tagToSlug,
} from "../utils/content";
import { type Locale } from "../i18n/config";
import { getMessages } from "../i18n";
import { normalizeForSearch } from "../utils/searchNormalize";

type Props = {
  post: Post;
  locale: Locale;
  imageSide?: "left" | "right";
};

const { post, locale, imageSide = "left" } = Astro.props;
const messages = getMessages(locale);

const href = getPostUrl(post.slug, locale);
const tags = getPostTags(post);
const readingTime = calculateReadingTime(post.body);
const tagSlugs = tags.map(tagToSlug).join(" ");
const searchHaystack = normalizeForSearch(
  [post.data.title, post.data.description].filter(Boolean).join(" ")
);
---

<article
  class:list={["highlighted-card", `image-${imageSide}`]}
  data-href={href}
  data-tag-slugs={tagSlugs}
  data-search={searchHaystack}
>
  <a class="cover" href={href} tabindex="-1" aria-hidden="true">
    {post.data.heroImage && (
      <img
        src={post.data.heroImage}
        alt=""
        width={720}
        height={540}
        loading="lazy"
      />
    )}
  </a>
  <div class="body">
    {tags.length > 0 && (
      <div class="tags">
        {tags.map((tag) => <TagChip tag={tag} locale={locale} />)}
      </div>
    )}
    <h3 class="title">
      <a href={href}>{post.data.title}</a>
    </h3>
    <p class="excerpt">{post.data.description}</p>
    <footer class="meta">
      <div class="author">
        <img
          src={messages.author.avatar}
          alt=""
          width="32"
          height="32"
          aria-hidden="true"
        />
        <span>{messages.author.name}</span>
      </div>
      <span class="reading-time">
        <FormattedDate date={post.data.pubDate} locale={locale} />
        <span aria-hidden="true"> · </span>
        {readingTime} {messages.blog.minReadCard}
      </span>
    </footer>
  </div>
</article>

<style>
  .highlighted-card {
    background: var(--color-white);
    border-radius: var(--radius-card);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    box-shadow: 0 4px 12px rgba(var(--gray), 12%);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    min-height: 320px;
  }

  .highlighted-card.image-right {
    grid-template-columns: 1fr 1.1fr;
  }

  .highlighted-card.image-right .cover {
    order: 2;
  }

  .highlighted-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(var(--gray), 20%);
  }

  .cover {
    display: block;
    overflow: hidden;
    background: var(--color-black-pearl-50);
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .body {
    padding: 2em;
    display: flex;
    flex-direction: column;
    gap: 0.8em;
    justify-content: center;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .title {
    margin: 0;
    font-size: 1.6em;
    line-height: 1.15;
    color: var(--color-black-pearl-900);
  }

  .title a {
    color: inherit;
    text-decoration: none;
  }

  .title a:hover {
    color: var(--color-aquarius-700);
  }

  .excerpt {
    margin: 0;
    color: var(--color-black-pearl-700);
    font-size: 0.9em;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta {
    margin-top: 0.4em;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8em;
    font-size: 0.8em;
    color: var(--color-black-pearl-400);
  }

  .author {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-black-pearl-700);
    font-weight: 700;
    line-height: 1;
  }

  .author img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--color-aquarius-100);
  }

  @media (max-width: 920px) {
    .highlighted-card,
    .highlighted-card.image-right {
      grid-template-columns: 1fr;
    }

    .highlighted-card.image-right .cover {
      order: 0;
    }

    .cover {
      aspect-ratio: 16 / 9;
    }

    .body {
      padding: 1.25em;
    }

    .title {
      font-size: 1.25em;
    }
  }
</style>
