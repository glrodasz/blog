---
import { type Locale, getLocaleFromAstro } from "../i18n/config";
import { getMessages } from "../i18n";

type Props = {
  locale?: Locale;
};

const locale = getLocaleFromAstro(Astro);
const messages = getMessages(locale);
---

<form
  class="subscribe-form"
  data-submit-label={messages.subscribe.submit}
  data-submitting-label={messages.subscribe.submitting}
  data-thanks={messages.subscribe.thanks}
  data-error={messages.subscribe.error}
>
  <label class="sr-only" for="subscribe-email">
    {messages.subscribe.placeholder}
  </label>
  <input
    id="subscribe-email"
    type="email"
    name="email"
    placeholder={messages.subscribe.placeholder}
    autocomplete="email"
    required
  />
  <button type="submit">{messages.subscribe.submit}</button>
  <p class="subscribe-form__error" role="alert" hidden></p>
</form>

<style>
  .subscribe-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    max-width: 520px;
    width: 100%;
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .subscribe-form input {
    flex: 1;
    padding: 14px 18px;
    border: none;
    background: rgba(255, 255, 255, 0.9);
    color: var(--color-black-pearl-900);
    font-size: 16px;
    font-family: inherit;
    min-width: 0;
  }

  .subscribe-form input:focus {
    outline: 2px solid var(--color-aquarius-600);
    outline-offset: -2px;
  }

  .subscribe-form input::placeholder {
    color: var(--color-black-pearl-400);
  }

  .subscribe-form button {
    padding: 14px 22px;
    background: var(--color-aquarius-600);
    color: var(--color-white);
    border: none;
    font-weight: 700;
    font-size: 15px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s ease;
  }

  .subscribe-form button:hover {
    background: var(--color-aquarius-700);
  }

  .subscribe-form button[disabled] {
    opacity: 0.7;
    cursor: progress;
  }

  .subscribe-form.success {
    background: rgba(53, 182, 200, 0.15);
    justify-content: center;
    padding: 14px 18px;
    color: var(--color-white);
    font-weight: 700;
  }

  .subscribe-form__error {
    flex-basis: 100%;
    margin: 8px 2px 0;
    padding: 0;
    color: #ffb4b4;
    font-size: 14px;
  }
</style>

<script>
  type FormState = {
    form: HTMLFormElement;
    input: HTMLInputElement;
    button: HTMLButtonElement;
    errorEl: HTMLElement;
  };

  const showError = (state: FormState, message: string) => {
    state.errorEl.textContent = message;
    state.errorEl.hidden = false;
  };

  const clearError = (state: FormState) => {
    state.errorEl.textContent = "";
    state.errorEl.hidden = true;
  };

  const setSubmitting = (state: FormState, submitting: boolean) => {
    state.button.disabled = submitting;
    state.input.disabled = submitting;
    state.button.textContent = submitting
      ? (state.form.dataset.submittingLabel ?? "...")
      : (state.form.dataset.submitLabel ?? "Subscribe");
  };

  const showSuccess = (form: HTMLFormElement) => {
    const thanks = form.dataset.thanks ?? "Thanks!";
    form.classList.add("success");
    form.innerHTML = `<span>${thanks}</span>`;
  };

  const submit = async (state: FormState) => {
    clearError(state);
    setSubmitting(state, true);
    try {
      const response = await fetch("/api/subscribe", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ email: state.input.value.trim() })
      });
      if (!response.ok) throw new Error(`Request failed: ${response.status}`);
      showSuccess(state.form);
    } catch (error) {
      console.error(error);
      setSubmitting(state, false);
      showError(state, state.form.dataset.error ?? "Something went wrong.");
    }
  };

  document.addEventListener("DOMContentLoaded", () => {
    const forms = document.querySelectorAll<HTMLFormElement>(".subscribe-form");
    forms.forEach((form) => {
      const input = form.querySelector<HTMLInputElement>("input[type=email]");
      const button = form.querySelector<HTMLButtonElement>("button[type=submit]");
      const errorEl = form.querySelector<HTMLElement>(".subscribe-form__error");
      if (!input || !button || !errorEl) return;
      const state: FormState = { form, input, button, errorEl };

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        if (!input.checkValidity()) {
          input.reportValidity();
          return;
        }
        void submit(state);
      });
    });
  });
</script>
