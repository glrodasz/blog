      ></path>
    </svg>
    <span class="current-flag">{currentLocale.toUpperCase()}</span>
  </button>

  <div class="language-dropdown" id="language-dropdown">
    {
      otherLanguages.map((language) => (
        <a
          href={switchLocalePath(currentPath, language.code as Locale)}
          class="language-option"
          hreflang={language.code}
        >
          <span class="name">{language.name}</span>
        </a>
      ))
    }
  </div>
</div>

<style>
  .language-selector {
    position: relative;
    display: inline-block;
  }

  .language-button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5em;
    border-radius: 4px;
    color: var(--color-text-strong);
    transition: background-color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    margin-top: -5px;
  }

  .language-button:hover {
    background-color: rgba(var(--black), 5%);
  }

  .language-button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .language-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    border-radius: 8px;
    box-shadow: 0 4px 12px rgba(var(--black), 15%);
    min-width: 140px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.2s ease;
    z-index: 100;
    margin-top: 4px;
  }

  .language-selector:hover .language-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .language-selector.active .language-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .language-option {
    display: flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.75em 1em;
    color: var(--color-text-strong);
    text-decoration: none;
    transition: background-color 0.2s ease;
    border-radius: 4px;
    margin: 4px;
  }

  .language-option:hover {
    background-color: rgba(var(--black), 5%);
  }

  .language-option:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
    background-color: rgba(var(--black), 5%);
  }

  .language-option:first-child {
    margin-top: 0;
  }

  .language-option:last-child {
    margin-bottom: 0;
  }

  .current-flag {
    font-size: 0.9em;
    font-weight: 600;
  }

  .flag {
    font-size: 0.9em;
    font-weight: 600;
  }

  .name {
    font-size: 0.9em;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .language-selector:hover .language-dropdown {
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
    }

    .language-selector.active .language-dropdown {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .language-button svg {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const selector = document.querySelector<HTMLElement>(".language-selector");
    const button = selector?.querySelector<HTMLElement>(".language-button");
    const dropdown = document.getElementById("language-dropdown");
    if (!selector || !button || !dropdown) return;

    const sel = selector;
    const btn = button;

    const options = Array.from(dropdown.querySelectorAll<HTMLElement>(".language-option"));

    function open() {
      sel.classList.add("active");
      btn.setAttribute("aria-expanded", "true");
      const first = options[0];
      if (first) first.focus();
    }

    function close(returnFocus = true) {
      sel.classList.remove("active");
      btn.setAttribute("aria-expanded", "false");
      if (returnFocus) btn.focus();
    }

    function isOpen() {
      return sel.classList.contains("active");
    }

    btn.addEventListener("click", () => {
      isOpen() ? close(false) : open();
    });

    btn.addEventListener("keydown", (ev) => {
      const e = ev as KeyboardEvent;
      if (e.key === "Enter" || e.key === " " || e.key === "ArrowDown") {
        e.preventDefault();
        if (!isOpen()) open();
      }
      if (e.key === "Escape") close();
    });

    dropdown.addEventListener("keydown", (ev) => {
      const e = ev as KeyboardEvent;
      if (e.key === "Escape") {
        e.preventDefault();
        close();
      }
    });

    // Close when focus leaves the selector entirely (Tab past last option)
    sel.addEventListener("focusout", (ev) => {
      const e = ev as FocusEvent;
      if (!sel.contains(e.relatedTarget as Node)) close(false);
    });

    document.addEventListener("click", (e) => {
      if (!sel.contains(e.target as Node)) close(false);
    });
  });
</script>
