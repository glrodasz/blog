---
import {
  type Locale,
  switchLocalePath,
  LANGUAGE_CONFIG,
  LOCALES,
} from "../i18n/config";
import { getMessages } from "../i18n";
import LanguageIcon from "./LanguageIcon.astro";

type Props = {
  currentLocale: Locale;
  currentPath: string;
};

const { currentLocale, currentPath } = Astro.props;
const messages = getMessages(currentLocale);

const otherLocale = LOCALES.find((code) => code !== currentLocale)!;
const currentLanguage = LANGUAGE_CONFIG[currentLocale];
const otherLanguage = LANGUAGE_CONFIG[otherLocale];
const switchHref = switchLocalePath(currentPath, otherLocale);
const switchLabel = messages.navigation.switchToLanguage.replace(
  "{language}",
  otherLanguage.name
);
---

<a
  href={switchHref}
  class="language-toggle"
  hreflang={otherLocale}
  lang={otherLocale}
  aria-label={switchLabel}
  title={switchLabel}
>
  <LanguageIcon />
  <span class="language-label">{currentLanguage.name}</span>
</a>

<style>
  .language-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.4em 0.5em;
    border: none;
    border-radius: 4px;
    background: none;
    color: var(--color-text-strong);
    font-size: inherit;
    font-family: inherit;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .language-toggle:hover {
    background-color: rgba(var(--black), 5%);
  }

  .language-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .language-label {
    font-size: inherit;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
</style>
