---
import Container from "./Container.astro";
import NavigationLink from "./NavigationLink.astro";
import BootcampButton from "./BootcampButton.astro";
import DiscordButton from "./DiscordButton.astro";
import LanguageSelector from "./LanguageSelector.astro";
import ThemeToggle from "./ThemeToggle.astro";
import {
  type Locale,
  getLocaleFromAstro,
  DEFAULT_LOCALE,
} from "../i18n/config";
import { getMessages } from "../i18n";

type Props = {
  locale?: Locale;
};

const locale = getLocaleFromAstro(Astro);
const messages = getMessages(locale);
const currentPath = Astro.url.pathname;
const homeHref = locale === DEFAULT_LOCALE ? "/" : `/${locale}/`;
---

<a href="#main-content" class="skip-link">{messages.navigation.skipToMain}</a>
<header id="main-header">
  <Container>
    <nav>
      <a href={homeHref} class="brand">
        <img
          src="/favicon.svg"
          alt=""
          width="40"
          height="40"
          class="brand-mark"
          aria-hidden="true"
        />
        <span class="brand-text">
          <span class="brand-title">
            <strong>Undefined</strong>Shell
          </span>
          <span class="brand-tag">{messages.site.shortDescription}</span>
        </span>
      </a>
      <div class="navigation">
        <div class="internal-links">
          <NavigationLink href="/" locale={locale}
            >{messages.navigation.home}</NavigationLink
          >
          <NavigationLink href="/about" locale={locale}
            >{messages.navigation.about}</NavigationLink
          >
          <LanguageSelector currentLocale={locale} currentPath={currentPath} />
          <ThemeToggle />
        </div>
        <div class="buttons-container">
          <BootcampButton />
          <DiscordButton />
        </div>
      </div>
    </nav>
  </Container>
</header>

<style>
  .skip-link {
    position: absolute;
    top: -9999px;
    left: 0;
    z-index: 9999;
    padding: 0.75em 1.25em;
    background: var(--color-bg-inverse);
    color: var(--color-text-on-inverse);
    font-weight: 700;
    text-decoration: none;
    border-radius: 0 0 4px 0;
  }

  .skip-link:focus {
    top: 0;
  }

  header {
    margin: 0;
    width: 100%;
    position: fixed;
    padding: 0;
    background: var(--color-header-bg);
    box-shadow: none;
    backdrop-filter: none;
    z-index: 10;
  }

  header.scrolled {
    background: var(--color-header-bg-scrolled);
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
    backdrop-filter: blur(10px);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6em 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text-strong);
  }

  .brand-mark {
    display: block;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1;
  }

  .brand-title {
    white-space: nowrap;
    font-family: var(--font-title);
    font-size: 22px;
    letter-spacing: 0.03em;
  }

  .brand-title strong {
    font-weight: 700;
  }

  .brand-tag {
    margin-top: 4px;
    font-size: 11px;
    color: var(--color-aquarius-600);
    letter-spacing: 0.12em;
    text-transform: lowercase;
    white-space: nowrap;
  }

  .navigation {
    display: flex;
    align-items: center;
    gap: 1.5em;
  }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 0.8em;
  }

  .buttons-container {
    display: flex;
    align-items: center;
    gap: 0.8em;
  }

  @media (max-width: 1200px) {
    .buttons-container {
      display: none;
    }

    .brand-tag {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .internal-links > a {
      display: none;
    }

    .brand-title {
      font-size: 16px;
    }
  }
</style>

<script>
  const BRAND_TAG_BASE_PX = 11;
  const BRAND_TAG_SIZE_MIN = 7;
  const BRAND_TAG_SIZE_MAX = 16;

  function fitBrandTag() {
    const brand = document.querySelector(".brand .brand-text");
    const title = brand?.querySelector(".brand-title");
    const tag = brand?.querySelector(".brand-tag");
    if (!title || !tag) return;
    if (!(tag instanceof HTMLElement)) return;
    if (getComputedStyle(tag).display === "none") {
      tag.style.removeProperty("font-size");
      return;
    }
    const targetW = title.getBoundingClientRect().width;
    if (targetW < 1) return;
    tag.style.removeProperty("font-size");
    tag.style.fontSize = `${BRAND_TAG_BASE_PX}px`;
    const w = tag.scrollWidth;
    if (w < 0.1) return;
    let size = (BRAND_TAG_BASE_PX * targetW) / w;
    size = Math.max(BRAND_TAG_SIZE_MIN, Math.min(BRAND_TAG_SIZE_MAX, size));
    tag.style.fontSize = `${size}px`;
  }

  function handleScroll() {
    const header = document.getElementById("main-header");
    if (!header) return;
    if (window.scrollY > 0) {
      header.classList.add("scrolled");
    } else {
      header.classList.remove("scrolled");
    }
  }

  function setupBrandTagFit() {
    const run = () => {
      requestAnimationFrame(() => {
        void document.fonts.ready.then(() => {
          requestAnimationFrame(fitBrandTag);
        });
      });
    };
    const header = document.getElementById("main-header");
    if (header) {
      const ro = new ResizeObserver(run);
      ro.observe(header);
    }
    const mq = window.matchMedia("(min-width: 1201px)");
    mq.addEventListener("change", run);
    run();
  }

  document.addEventListener("DOMContentLoaded", () => {
    window.addEventListener("scroll", handleScroll);
    handleScroll();
    setupBrandTagFit();
  });
  window.addEventListener("load", () => {
    void document.fonts.ready.then(() => {
      requestAnimationFrame(fitBrandTag);
    });
  });
</script>
