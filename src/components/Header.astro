---
import Container from "./Container.astro";
import NavigationLink from "./NavigationLink.astro";
import BootcampButton from "./BootcampButton.astro";
import DiscordButton from "./DiscordButton.astro";
import LanguageSelector from "./LanguageSelector.astro";
import {
  type Locale,
  getLocaleFromAstro,
  DEFAULT_LOCALE,
} from "../i18n/config";
import { getMessages } from "../i18n";

type Props = {
  locale?: Locale;
};

const locale = getLocaleFromAstro(Astro);
const messages = getMessages(locale);
const currentPath = Astro.url.pathname;
const homeHref = locale === DEFAULT_LOCALE ? "/" : `/${locale}/`;
---

<header id="main-header">
  <Container>
    <nav>
      <a href={homeHref} class="brand">
        <img
          src="/favicon.svg"
          alt=""
          width="40"
          height="40"
          class="brand-mark"
          aria-hidden="true"
        />
        <span class="brand-text">
          <span class="brand-title">
            <strong>Undefined</strong>Shell
          </span>
          <span class="brand-tag">{messages.site.shortDescription}</span>
        </span>
      </a>
      <div class="navigation">
        <div class="internal-links">
          <NavigationLink href="/" locale={locale}
            >{messages.navigation.home}</NavigationLink
          >
          <a href="#subscribe" class="nav-link subscribe-link">
            {messages.navigation.subscribe}
          </a>
          <NavigationLink href="/about" locale={locale}
            >{messages.navigation.about}</NavigationLink
          >
          <LanguageSelector currentLocale={locale} currentPath={currentPath} />
        </div>
        <div class="buttons-container">
          <BootcampButton />
          <DiscordButton />
        </div>
      </div>
    </nav>
  </Container>
</header>

<style>
  header {
    margin: 0;
    width: 100%;
    position: fixed;
    padding: 0;
    background: white;
    box-shadow: none;
    backdrop-filter: none;
    z-index: 10;
  }

  header.scrolled {
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
    backdrop-filter: blur(10px);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6em 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-black-pearl-900);
  }

  .brand-mark {
    display: block;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .brand-title {
    font-size: 18px;
    letter-spacing: 0.01em;
  }

  .brand-title strong {
    font-weight: 700;
  }

  .brand-tag {
    font-size: 11px;
    color: var(--color-aquarius-600);
    letter-spacing: 0.12em;
    text-transform: lowercase;
    margin-top: 4px;
  }

  .nav-link {
    padding: 1em 0.2em;
    color: var(--color-black-pearl-900);
    text-decoration: none;
    border-bottom: 4px solid transparent;
  }

  .nav-link:hover {
    color: var(--color-aquarius-700);
  }

  .subscribe-link {
    font-weight: 700;
    color: var(--color-aquarius-600);
  }

  .navigation {
    display: flex;
    align-items: center;
    gap: 1.5em;
  }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 0.8em;
  }

  .buttons-container {
    display: flex;
    align-items: center;
    gap: 0.8em;
  }

  @media (max-width: 1200px) {
    .buttons-container {
      display: none;
    }

    .brand-tag {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .internal-links .nav-link {
      display: none;
    }
  }
</style>

<script>
  function handleScroll() {
    const header = document.getElementById("main-header");
    if (!header) return;
    if (window.scrollY > 0) {
      header.classList.add("scrolled");
    } else {
      header.classList.remove("scrolled");
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    window.addEventListener("scroll", handleScroll);
    handleScroll();
  });
</script>
