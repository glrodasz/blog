---
import { type Locale, LANGUAGE_CONFIG } from "../i18n/config";
import { getMessages } from "../i18n";
import LanguageIcon from "./LanguageIcon.astro";

type LanguageVersion = {
  language: string;
  url: string;
};

type Props = {
  languageVersions?: LanguageVersion[];
  currentLocale: Locale;
};

const { languageVersions, currentLocale } = Astro.props;

if (!languageVersions || languageVersions.length === 0) {
  return null;
}

const otherVersions = languageVersions.filter(
  (version) => version.language !== currentLocale
);

if (otherVersions.length === 0) {
  return null;
}

const formatMessage = (template: string, language: string) => {
  return template.replace("{language}", language);
};
---

{
  otherVersions.map((version) => {
    const versionLocale = version.language as Locale;
    const targetMessages = getMessages(versionLocale);
    const languageName =
      LANGUAGE_CONFIG[versionLocale as keyof typeof LANGUAGE_CONFIG]?.name ||
      version.language.toUpperCase();
    const linkLabel = formatMessage(
      targetMessages.languageBanner.readIn,
      languageName
    );

    return (
      <span class="translation-meta">
        <span class="meta-sep" aria-hidden="true">
          •
        </span>
        <LanguageIcon size={16} />
        <a
          href={version.url}
          hreflang={version.language}
          lang={version.language}
        >
          {linkLabel}
        </a>
      </span>
    );
  })
}

<style>
  .translation-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
  }

  .meta-sep {
    margin-right: 0.15em;
  }

  .translation-meta :global(.language-icon) {
    flex-shrink: 0;
  }

  .translation-meta a {
    color: inherit;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .translation-meta a:hover {
    color: var(--color-accent-hover);
  }

  .translation-meta a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
