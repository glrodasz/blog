---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Container from "../components/Container.astro";
import SimpleAnalytics from "../components/SimpleAnalytics.astro";
import LanguageVersionBanner from "../components/LanguageVersionBanner.astro";
import TagChip from "../components/TagChip.astro";
import BackLink from "../components/BackLink.astro";
import AuthorBio from "../components/AuthorBio.astro";
import ShareButtons from "../components/ShareButtons.astro";
import RelatedPosts from "../components/RelatedPosts.astro";
import DiscordCallout from "../components/DiscordCallout.astro";
import { type Locale, getLocaleFromAstro } from "../i18n/config";
import { getMessages } from "../i18n";
import { Link } from "lucide";
import Info from "lucide-astro/Info";

const linkIconPaths = Link;

type LanguageVersion = {
  language: string;
  url: string;
};

type Props = CollectionEntry<"posts">["data"] & {
  readingTime?: number;
  locale?: Locale;
  languageVersions?: LanguageVersion[];
  isPage?: boolean;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  readingTime,
  languageVersions,
  tags: rawTags,
  relatedPosts,
  isPage = false,
} = Astro.props;

const locale = getLocaleFromAstro(Astro);
const messages = getMessages(locale);
const tabTitle = `${title} • ${messages.site.shortDescription} • ${messages.site.title} by ${messages.site.author}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "http://localhost/").href;

const localePrefix = locale === "es" ? "es/" : "";
const computedImage = heroImage ?? (isPage ? `/og/${localePrefix}about.png` : `/og/${localePrefix}home.png`);

const tags = rawTags
  ? Array.isArray(rawTags)
    ? rawTags
    : [rawTags]
  : [];
---

<html lang={locale}>
  <head>
    <BaseHead
      title={title}
      tabTitle={tabTitle}
      description={description}
      image={computedImage}
      imageAlt={title}
      type={isPage ? "website" : "article"}
      locale={locale}
    />
    {!isPage && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": title,
        "description": description,
        "image": new URL(computedImage, Astro.site ?? "https://undefined.sh").href,
        "datePublished": pubDate.toISOString(),
        "dateModified": (updatedDate ?? pubDate).toISOString(),
        "author": { "@type": "Person", "name": "Guillermo Rodas", "url": "https://undefined.sh" },
        "publisher": { "@type": "Organization", "name": "Undefined Shell", "url": "https://undefined.sh" },
        "url": canonicalUrl,
        "inLanguage": locale,
      })} />
    )}
  </head>
  <body>
    <Header locale={locale} />
    <main id="main-content" class="article-page" tabindex="-1">
      <Container>
        <div class="post-head">
          <BackLink />
          {tags.length > 0 && (
            <div class="post-tags">
              {tags.map((tag) => <TagChip tag={tag} locale={locale} />)}
            </div>
          )}
          <h1 class="post-title">{title}</h1>
          {!isPage && (
            <div class="post-meta">
              <FormattedDate date={pubDate} locale={locale} />
              {updatedDate && (
                <span
                  class="last-updated-on"
                  tabindex="0"
                  role="note"
                  aria-label={messages.blog.updatedLabel}
                  aria-describedby="last-updated-date"
                >
                  ({messages.blog.updatedLabel}
                  <Info class="last-updated-icon" aria-hidden="true" />)
                  <span class="last-updated-tooltip" role="tooltip" id="last-updated-date">
                    <FormattedDate date={updatedDate} locale={locale} />
                  </span>
                </span>
              )}
              {readingTime && (
                <span class="reading-time">
                  • {readingTime} {messages.blog.minRead}
                </span>
              )}
            </div>
          )}
        </div>
      </Container>

      {heroImage && (
        <div class="hero-image">
          <Container>
            <img width={1200} height={510} src={heroImage} alt={title} />
          </Container>
        </div>
      )}

      <Container>
        <article>
          <div class="prose">
            <LanguageVersionBanner
              languageVersions={languageVersions}
              currentLocale={locale}
            />
            <div class="blog-content">
              <slot />
            </div>
          </div>
        </article>
        {!isPage && (
          <section class="post-footer">
            <AuthorBio locale={locale} />
            <ShareButtons locale={locale} title={title} url={canonicalUrl} />
          </section>
        )}
      </Container>

      <RelatedPosts slugs={relatedPosts} locale={locale} />

      <DiscordCallout locale={locale} />
    </main>
    <Footer locale={locale} />
    <SimpleAnalytics />
    <script define:vars={{ linkIconPaths: JSON.stringify(linkIconPaths), copyLinkLabel: messages.blog.copyHeadingLink }}>
      const linkIconData = JSON.parse(linkIconPaths);
      const headings = Array.from(
        document.querySelectorAll(
          ".blog-content h2[id], .blog-content h3[id], .blog-content h4[id], .blog-content h5[id], .blog-content h6[id]"
        )
      );

      const copyLinkToClipboard = async (url) => {
        if (navigator.clipboard?.writeText) {
          try {
            await navigator.clipboard.writeText(url);
            return true;
          } catch (error) {
            console.warn(
              "Clipboard write failed, falling back to execCommand.",
              error
            );
          }
        }

        const helper = document.createElement("textarea");
        helper.value = url;
        helper.setAttribute("readonly", "");
        helper.style.position = "absolute";
        helper.style.left = "-9999px";
        document.body.appendChild(helper);
        helper.select();
        const copied = document.execCommand("copy");
        document.body.removeChild(helper);
        return copied;
      };

      const handleCopy = (heading) => {
        const id = heading.id;
        if (!id) return;
        const url = `${window.location.origin}${window.location.pathname}#${id}`;

        window.history.replaceState(null, "", `#${id}`);
        copyLinkToClipboard(url);
        heading.classList.add("copied");
        window.setTimeout(() => heading.classList.remove("copied"), 1500);
      };

      headings.forEach((heading) => {
        if (!(heading instanceof HTMLHeadingElement)) return;
        if (heading.dataset.shareableHeading === "true" || !heading.id) return;

        const headingText = heading.textContent?.trim() ?? "section";
        heading.dataset.shareableHeading = "true";
        heading.classList.add("shareable-heading");
        // Pin the heading's accessible name to its text content so that the
        // button appended below is excluded from heading-navigation announcements.
        heading.setAttribute("aria-label", headingText);

        const copyBtn = document.createElement("button");
        copyBtn.className = "heading-copy-btn";
        copyBtn.setAttribute("type", "button");
        copyBtn.setAttribute("aria-label", `${copyLinkLabel}: "${headingText}"`);
        copyBtn.innerHTML = `
          <svg aria-hidden="true" width="0.75em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            ${linkIconData.map(([_, attrs]) => `<path d="${attrs.d}" />`).join("")}
          </svg>
        `;

        copyBtn.addEventListener("click", (event) => {
          event.preventDefault();
          handleCopy(heading);
        });

        heading.appendChild(copyBtn);
      });
    </script>
    <style>
      .post-head {
        padding: 1.5em 0 0.5em;
        display: flex;
        flex-direction: column;
        gap: 1em;
      }

      .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .post-title {
        margin: 0;
        font-size: 3em;
        line-height: 1.05;
        color: var(--color-black-pearl-900);
      }

      .post-meta {
        color: var(--color-aquarius-600);
        font-size: 0.9em;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5em;
      }

      .post-meta :global(time) {
        margin: 0;
      }

      .last-updated-on {
        color: var(--color-black-pearl-400);
        position: relative;
        cursor: help;
        outline: none;
        display: inline-flex;
        align-items: center;
      }

      .last-updated-icon {
        width: 0.9em;
        height: 0.9em;
        stroke-width: 2;
        margin-left: 0.2em;
      }

      .last-updated-tooltip {
        position: absolute;
        bottom: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
        background: var(--color-black-pearl-900);
        color: #fff;
        font-size: 0.85em;
        padding: 4px 8px;
        border-radius: 4px;
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.15s ease;
        z-index: 1;
      }

      .last-updated-tooltip::after {
        content: "";
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 4px solid transparent;
        border-top-color: var(--color-black-pearl-900);
      }

      .last-updated-on:hover .last-updated-tooltip,
      .last-updated-on:focus .last-updated-tooltip,
      .last-updated-on:focus-within .last-updated-tooltip {
        opacity: 1;
      }

      .hero-image {
        margin: 1.25em 0;
      }

      .hero-image img {
        display: block;
        margin: 0 auto;
        aspect-ratio: 48 / 18;
        object-fit: cover;
        width: 100%;
        border-radius: var(--radius-card);
      }

      .prose {
        max-width: 920px;
        width: 100%;
        margin: 0 auto;
        color: var(--color-black-pearl-700);
      }

      .blog-content {
        margin-top: 2rem;
      }

      .post-footer {
        max-width: 920px;
        width: 100%;
        margin: 2.5em auto 0;
        padding: 2em 0;
        border-top: 1px solid var(--color-black-pearl-50);
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1.5em;
        flex-wrap: wrap;
      }

      @media (max-width: 920px) {
        .post-title {
          font-size: 2.2em;
        }

        .hero-image img {
          aspect-ratio: 24 / 12;
        }
      }
    </style>
  </body>
</html>
