---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Container from "../../components/Container.astro";
import SimpleAnalytics from "../../components/SimpleAnalytics.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getPostsByLanguage, getCleanSlug } from "../../utils/content";
import { getMessages } from "../../i18n";

const locale = "es";
const messages = getMessages(locale);

const allPosts = (await getPostsByLanguage(locale)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const posts = allPosts.slice(0, 3);
const allSlugs = allPosts.map((p) => getCleanSlug(p.slug));
const basePostPath = "/es/posts/";
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead
      title={messages.notFound.tabTitle}
      description={messages.notFound.description}
      locale={locale}
    />
  </head>
  <body>
    <Header locale={locale} />
    <main id="main-content" tabindex="-1">
      <Container>
        <section class="hero">
          <div class="terminal">
            <div class="terminal-bar">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <div class="terminal-body">
              <p class="line">
                <span class="prompt">$</span>
                <span class="cmd">{messages.notFound.prompt}</span>
                <span id="attempted-path" class="arg"></span>
              </p>
              <p class="error-line">{messages.notFound.errorLine}</p>
              <p class="suggestion-line" id="suggestion-line" hidden>
                {messages.notFound.suggestion}
                <a id="suggestion-link" href="#"></a>
              </p>
              <p class="cursor-line"><span class="cursor">▌</span></p>
            </div>
          </div>
          <h1>{messages.notFound.title}</h1>
          <p class="desc">{messages.notFound.description}</p>
          <a class="back-home" href="/es/">{messages.notFound.backToHome}</a>
        </section>

        {posts.length > 0 && (
          <section class="suggestions">
            <h2>{messages.notFound.suggestionsTitle}</h2>
            <div class="cards-grid">
              {posts.map((post) => (
                <ArticleCard post={post} locale={locale} />
              ))}
            </div>
          </section>
        )}
      </Container>
    </main>
    <Footer locale={locale} />
    <SimpleAnalytics />

    <script define:vars={{ allSlugs, basePostPath }}>
      document.addEventListener("DOMContentLoaded", () => {
        const raw = window.location.pathname;

        const pathEl = document.getElementById("attempted-path");
        if (pathEl) pathEl.textContent = raw;

        const cleaned = raw
          .replace(/^\/es\//, "/")
          .replace(/^\/posts\//, "")
          .replace(/\/$/, "")
          .replace(/\.(html?|php|aspx?)$/i, "")
          .replace(/^\//, "");

        if (!cleaned) return;

        const tokens = cleaned.toLowerCase().split(/[-_/]+/).filter(Boolean);
        if (!tokens.length) return;

        let best = { slug: "", score: 0 };
        for (const slug of allSlugs) {
          const slugTokens = slug.toLowerCase().split("-");
          const overlap = tokens.filter((t) => slugTokens.includes(t)).length;
          if (overlap > best.score) {
            best = { slug, score: overlap };
          }
        }

        if (best.score > 0) {
          const href = `${basePostPath}${best.slug}/`;
          const link = document.getElementById("suggestion-link");
          const line = document.getElementById("suggestion-line");
          if (link && line) {
            link.textContent = href;
            link.setAttribute("href", href);
            line.hidden = false;
          }
        }
      });
    </script>
  </body>
</html>

<style>
  main {
    padding: 4em 0 6em;
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25em;
    padding: 3em 0 4em;
  }

  .terminal {
    width: 100%;
    max-width: 560px;
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
    font-family: ui-monospace, "Cascadia Code", "Fira Code", monospace;
    font-size: 0.9em;
    text-align: left;
  }

  .terminal-bar {
    background: #2d2d2d;
    padding: 0.6em 0.8em;
    display: flex;
    gap: 0.45em;
    align-items: center;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }

  .dot-red { background: #ef4444; }
  .dot-yellow { background: #f59e0b; }
  .dot-green { background: #22c55e; }

  .terminal-body {
    background: var(--color-aquarius-900);
    color: #e2e8f0;
    padding: 1.25em 1.4em 1.4em;
    display: flex;
    flex-direction: column;
    gap: 0.4em;
  }

  .line, .error-line, .suggestion-line, .cursor-line {
    margin: 0;
    line-height: 1.6;
  }

  .prompt {
    color: #22c55e;
    margin-right: 0.5em;
    user-select: none;
  }

  .cmd {
    color: #93c5fd;
    margin-right: 0.5em;
  }

  .arg {
    color: #fde68a;
    word-break: break-all;
  }

  .error-line {
    color: #fca5a5;
  }

  .suggestion-line {
    color: #7dd3fc;
  }

  .suggestion-line a {
    color: #7dd3fc;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .cursor-line {
    margin-top: 0.2em;
  }

  .cursor {
    display: inline-block;
    color: #22c55e;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  h1 {
    margin: 0;
    font-size: 2.5em;
  }

  .desc {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.05em;
    max-width: 400px;
  }

  .back-home {
    display: inline-block;
    color: var(--color-accent-fg);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95em;
    transition: color 0.15s ease;
  }

  .back-home:hover {
    color: var(--color-accent-hover);
  }

  .suggestions {
    border-top: 1px solid var(--color-border-default);
    padding-top: 3em;
  }

  .suggestions h2 {
    margin: 0 0 1.5em;
    font-size: 1.2em;
    color: var(--color-text-muted);
    font-weight: 500;
    text-align: center;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
  }

  @media (max-width: 1024px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 1.8em;
    }
  }
</style>
