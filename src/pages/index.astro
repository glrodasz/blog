---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/Container.astro";
import SimpleAnalytics from "../components/SimpleAnalytics.astro";
import FeaturedHero from "../components/FeaturedHero.astro";
import TagFilter from "../components/TagFilter.astro";
import SearchBar from "../components/SearchBar.astro";
import PostGrid from "../components/PostGrid.astro";
import DiscordCallout from "../components/DiscordCallout.astro";
import {
  getPostsByLanguage,
  collectTagsFromPosts,
} from "../utils/content";
import { getMessages } from "../i18n";
import { getLocaleFromAstro } from "../i18n/config";

const locale = getLocaleFromAstro(Astro);
const posts = (await getPostsByLanguage(locale)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const messages = getMessages(locale);
const tags = collectTagsFromPosts(posts);
const [featured, ...rest] = posts;
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead
      title={`${messages.site.title} by ${messages.site.author}`}
      tabTitle={`${messages.site.title} by ${messages.site.author} • ${messages.site.shortDescription}`}
      description={messages.site.description}
      image="/og/home.png"
      locale={locale}
    />
  </head>
  <body>
    <Header locale={locale} />
    <main id="main-content" class="home" tabindex="-1">
      {featured && <FeaturedHero post={featured} locale={locale} />}
      <section class="filter-bar">
        <Container>
          <div class="filter-inner">
            <TagFilter tags={tags} locale={locale} activeTagSlug="all" />
            <SearchBar locale={locale} />
          </div>
        </Container>
      </section>
      <PostGrid posts={rest} locale={locale} />
      <DiscordCallout locale={locale} />
    </main>
    <Footer locale={locale} />
    <SimpleAnalytics />
    <script>
      import { initHomeFilter } from "../utils/homeFilter";

      initHomeFilter();
    </script>
  </body>
</html>

<style>
  .filter-bar {
    padding: 1.5em 0 0.5em;
  }

  .filter-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: nowrap;
  }

  @media (max-width: 640px) {
    .filter-inner {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75em;
      flex-wrap: wrap;
    }
  }
</style>

<style is:global>
  /* Expanded-search state, scoped to search-input focus only (not tags or
     arrows, which are also focusable descendants of .filter-inner). Global
     because Astro can't scope :global() inside :has(). */
  @media (min-width: 641px) {
    .filter-inner:has([data-search-input]:focus) .tag-carousel {
      flex: 0 0 auto;
    }

    .filter-inner:has([data-search-input]:focus) .tag-filter-scroll {
      overflow: visible;
    }

    .filter-inner:has([data-search-input]:focus) .search-bar {
      flex: 1 1 auto;
    }

    .filter-inner:has([data-search-input]:focus) .tag-tab:not(.active) {
      display: none;
    }

    .filter-inner:has([data-search-input]:focus) .carousel-arrow {
      display: none;
    }
  }
</style>
